{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",
  "rules": {
    "files": "off"
  },
  "workspaces": {
    "apps/admin-ui": {
      "entry": ["src/main.tsx!"],
      "ignoreDependencies": ["@happy-dom/global-registrator"]
    },
    "apps/api": {
      "entry": ["src/index.ts!", "src/worker.ts!", "src/bull-board.ts!"],
      "ignoreBinaries": [
        "dist/index.js",
        "dist/worker.js",
        "dist/bull-board.js"
      ]
    }
  }
}
