{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",
  "ignoreUnresolved": ["bun-types"],
  "workspaces": {
    "apps/admin-ui": {
      "entry": ["src/main.tsx!"]
    },
    "apps/api": {
      "entry": ["src/index.ts!", "src/worker.ts!", "src/bull-board.ts!"],
      "ignoreBinaries": [
        "dist/index.js",
        "dist/worker.js",
        "dist/bull-board.js"
      ]
    }
  }
}
