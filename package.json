{
  "name": "@scheduling/root",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -w run --parallel \"/^dev:(api|admin|inngest)$/\"",
    "dev:api": "pnpm --filter @scheduling/api run dev",
    "dev:admin": "pnpm --filter @scheduling/admin-ui run dev",
    "dev:inngest": "INNGEST_DEV=1 DO_NOT_TRACK=1 pnpm exec inngest dev -u http://localhost:${PORT:-3000}/api/inngest --persist",
    "compile:api": "pnpm --filter @scheduling/api run compile",
    "start:api:compiled": "pnpm --filter @scheduling/api run start:compiled",
    "preview:admin": "pnpm --filter @scheduling/admin-ui run build && pnpm --filter @scheduling/admin-ui run preview -- --host",
    "db:migrate": "pnpm --filter @scheduling/db run migrate",
    "db:reset": "pnpm --filter @scheduling/db run reset",
    "db:seed": " pnpm --filter @scheduling/api run seed",
    "sdk:typescript:openapi": "pnpm --filter @scheduling/api run export:openapi:sdk",
    "sdk:typescript:generate": "pnpm run sdk:typescript:openapi && pnpm --filter @scheduling/client run generate",
    "bootstrap:dev": "set -a; [ -f ./.env ] && . ./.env; set +a; DATABASE_URL=${DB_PUSH_DATABASE_URL:-postgres://scheduling:scheduling@localhost:5433/scheduling} pnpm --filter @scheduling/db run push && pnpm db:seed",
    "db:reseed": "pnpm db:reset && pnpm db:migrate && pnpm db:seed",
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@scheduling/admin-ui --output-logs=errors-only",
    "build:all": "turbo run build --force",
    "build:changed": "turbo run build --filter='...[origin/main]'",
    "test": "turbo run test --output-logs=errors-only",
    "test:changed": "turbo run test --filter='...[origin/main]' --output-logs=errors-only",
    "test:coverage": "pnpm -r --workspace-concurrency=1 --stream run test:coverage",
    "knip": "knip --cache",
    "knip:deps": "knip --strict --dependencies --cache",
    "knip:deps:ci": "knip --strict --dependencies --max-issues 0 --no-progress",
    "knip:audit": "knip --no-exit-code --cache",
    "lint": "turbo run lint --output-logs=errors-only",
    "lint:all": "oxlint --type-aware .",
    "lint:changed": "turbo run lint --filter='...[origin/main]' --output-logs=errors-only",
    "format": "biome format . --write",
    "format:check": "biome check .",
    "typecheck": "turbo run typecheck --output-logs=errors-only",
    "typecheck:changed": "turbo run typecheck --filter='...[origin/main]'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "inngest-cli": "^1.17.1",
    "knip": "^5.85.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.14.2",
    "turbo": "^2.8.10",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.0",
  "overrides": {
    "postgres": "3.4.8"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "sdk/*"
    ],
    "catalog": {
      "@logtape/logtape": "^2.0.2",
      "@types/bun": "^1.3.8",
      "drizzle-orm": "1.0.0-beta.15-859cf75",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  }
}
