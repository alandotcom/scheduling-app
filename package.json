{
  "name": "@scheduling/root",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -w run --parallel \"/^dev:(api|admin|worker|bull-board)$/\"",
    "dev:api": "pnpm --filter @scheduling/api run dev",
    "dev:admin": "pnpm --filter @scheduling/admin-ui run dev",
    "dev:worker": "pnpm --filter @scheduling/api run dev:worker",
    "dev:bull-board": "pnpm --filter @scheduling/api run dev:bull-board",
    "preview:admin": "pnpm --filter @scheduling/admin-ui run build && pnpm --filter @scheduling/admin-ui run preview -- --host",
    "db:migrate": "pnpm --filter @scheduling/db run migrate",
    "db:reset": "pnpm --filter @scheduling/db run reset",
    "db:seed": " pnpm --filter @scheduling/api run seed",
    "db:reseed": "pnpm db:reset && pnpm db:migrate && pnpm db:seed",
    "build": "pnpm -r run build",
    "build:worker": "pnpm --filter @scheduling/api run build:worker",
    "build:bull-board": "pnpm --filter @scheduling/api run build:bull-board",
    "start:worker": "pnpm --filter @scheduling/api run start:worker",
    "start:bull-board": "pnpm --filter @scheduling/api run start:bull-board",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r --workspace-concurrency=1 --stream run test:coverage",
    "lint": "oxlint --type-aware .",
    "format": "biome format . --write",
    "format:check": "biome check .",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.11.5",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.29.1",
  "dependencies": {
    "@logtape/logtape": "^2.0.2",
    "@logtape/pretty": "^2.0.2"
  }
}
