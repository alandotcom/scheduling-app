{
  "name": "@scheduling/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./relations": "./src/relations.ts",
    "./test-utils": "./src/test-utils.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "LOG_LEVE=fatal bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --incremental --tsBuildInfoFile node_modules/.cache.typecheck.tsbuildinfo --pretty false",
    "migrate": "bun --bun node_modules/drizzle-kit/bin.cjs migrate",
    "generate": "bun --bun node_modules/drizzle-kit/bin.cjs generate",
    "push": "bun --bun node_modules/drizzle-kit/bin.cjs push",
    "reset": "bun run src/reset.ts",
    "seed": "bun run src/seed.ts"
  },
  "dependencies": {
    "@logtape/logtape": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "drizzle-kit": "beta",
    "typescript": "catalog:"
  }
}
