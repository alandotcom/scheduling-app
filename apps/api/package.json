{
  "name": "@scheduling/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./router-type": {
      "types": "./src/router-type.ts"
    }
  },
  "scripts": {
    "dev": "set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${API_PORT:-${PORT:-3000}} bun --env-file=../../.env --hot src/index.ts",
    "dev:worker": "bun --env-file=../../.env --hot src/worker.ts",
    "dev:workflow-worker": "pnpm run workflow:build && set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${WORKFLOW_WORKER_PORT:-3020} WORKFLOW_TARGET_WORLD=@workflow/world-postgres WORKFLOW_POSTGRES_URL=${WORKFLOW_POSTGRES_URL:-${DATABASE_URL:-postgres://scheduling:scheduling@localhost:5433/scheduling}} bun --env-file=../../.env --hot src/workflow-worker.ts",
    "dev:bull-board": "bun --env-file=../../.env --hot src/bull-board.ts",
    "workflow:build": "rm -f dist/workflow-worker.js && workflow build",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "build:worker": "bun build ./src/worker.ts --outdir ./dist --target bun",
    "build:workflow-worker": "pnpm run workflow:build && bun build ./src/workflow-worker.ts --outdir ./dist --target bun",
    "build:bull-board": "bun build ./src/bull-board.ts --outdir ./dist --target bun",
    "start": "set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${API_PORT:-${PORT:-3000}} bun dist/index.js",
    "start:worker": "bun dist/worker.js",
    "start:workflow-worker": "pnpm run build:workflow-worker && set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${WORKFLOW_WORKER_PORT:-3020} WORKFLOW_TARGET_WORLD=@workflow/world-postgres WORKFLOW_POSTGRES_URL=${WORKFLOW_POSTGRES_URL:-${DATABASE_URL:-postgres://scheduling:scheduling@localhost:5433/scheduling}} bun dist/workflow-worker.js",
    "start:bull-board": "bun dist/bull-board.js",
    "test": "LOG_LEVEL=fatal bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --incremental --tsBuildInfoFile node_modules/.cache.typecheck.tsbuildinfo --pretty false",
    "seed": "bun --env-file=../../.env src/scripts/seed.ts",
    "sync:svix-event-catalog": "bun --env-file=../../.env src/scripts/sync-svix-event-catalog.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.17.0",
    "@bull-board/hono": "^6.17.0",
    "@integrations/core": "workspace:*",
    "@integrations/logger": "workspace:*",
    "@logtape/logtape": "catalog:",
    "@orpc/openapi": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/zod": "^1.13.4",
    "@scheduling/db": "workspace:*",
    "@scheduling/dto": "workspace:*",
    "@swc/core": "^1.15.11",
    "@workflow/swc-plugin": "4.1.0-beta.17",
    "@workflow/world-postgres": "4.1.0-beta.32",
    "better-auth": "^1.4.18",
    "bullmq": "^5.67.3",
    "drizzle-orm": "catalog:",
    "es-toolkit": "^1.44.0",
    "hono": "^4.11.9",
    "libphonenumber-js": "^1.12.36",
    "luxon": "^3.7.2",
    "rrule": "^2.8.1",
    "standardenv": "^0.0.2",
    "svix": "^1.84.1",
    "workflow": "4.1.0-beta.54",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bun": "catalog:",
    "@types/luxon": "^3.7.1",
    "typescript": "catalog:"
  }
}
