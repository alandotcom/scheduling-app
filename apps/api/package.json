{
  "name": "@scheduling/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./router-type": {
      "types": "./src/router-type.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --hot src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "lint": "pnpm --dir ../.. exec oxlint --type-aware --config .oxlintrc.json --tsconfig tsconfig.json apps/api",
    "compile": "bun build ./src/index.ts --compile --outfile ./dist/server --target ${BUN_COMPILE_TARGET:-bun}",
    "start": "set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${API_PORT:-${PORT:-3000}} bun dist/index.js",
    "start:compiled": "set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${API_PORT:-${PORT:-3000}} ./dist/server",
    "test": "LOG_LEVEL=fatal bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsgo -p tsconfig.typecheck.json --noEmit --incremental --tsBuildInfoFile node_modules/.cache.typecheck.tsbuildinfo --pretty false",
    "seed": "bun --env-file=../../.env src/scripts/seed.ts",
    "export:openapi:sdk": "bun --env-file=../../.env src/scripts/export-openapi-sdk.ts",
    "sync:svix-event-catalog": "bun --env-file=../../.env src/scripts/sync-svix-event-catalog.ts",
    "eval": "set -a; [ -f ../../.env ] && . ../../.env; set +a; evalite",
    "eval:watch": "set -a; [ -f ../../.env ] && . ../../.env; set +a; evalite watch"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.133",
    "@better-auth/api-key": "^1.6.20",
    "@logtape/logtape": "catalog:",
    "@marcbachmann/cel-js": "^7.6.1",
    "@orpc/openapi": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "@orpc/zod": "^1.14.6",
    "@scheduling/db": "workspace:*",
    "@scheduling/dto": "workspace:*",
    "ai": "^6.0.208",
    "better-auth": "^1.6.20",
    "drizzle-orm": "catalog:",
    "es-toolkit": "^1.47.1",
    "hono": "^4.12.26",
    "inngest": "^4.7.0",
    "libphonenumber-js": "^1.13.7",
    "lru-cache": "^11.5.1",
    "luxon": "^3.7.2",
    "parse-duration": "^2.1.6",
    "resend": "^6.14.0",
    "rrule": "^2.8.1",
    "standardenv": "^0.1.0",
    "superjson": "^2.2.6",
    "svix": "^1.96.0",
    "twilio": "^5.13.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@faker-js/faker": "^10.5.0",
    "@inngest/test": "^1.0.0",
    "@types/bun": "catalog:",
    "@types/luxon": "^3.7.2",
    "autoevals": "^0.3.0",
    "better-sqlite3": "11.10.0",
    "evalite": "1.0.0-beta.16",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
