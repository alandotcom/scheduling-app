{
  "name": "@scheduling/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./router-type": {
      "types": "./src/router-type.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --hot src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "compile": "bun build ./src/index.ts --compile --outfile ./dist/server --target ${BUN_COMPILE_TARGET:-bun}",
    "start": "set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${API_PORT:-${PORT:-3000}} bun dist/index.js",
    "start:compiled": "set -a; [ -f ../../.env ] && . ../../.env; set +a; PORT=${API_PORT:-${PORT:-3000}} ./dist/server",
    "test": "LOG_LEVEL=fatal bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --incremental --tsBuildInfoFile node_modules/.cache.typecheck.tsbuildinfo --pretty false",
    "seed": "bun --env-file=../../.env src/scripts/seed.ts",
    "sync:svix-event-catalog": "bun --env-file=../../.env src/scripts/sync-svix-event-catalog.ts"
  },
  "dependencies": {
    "@integrations/core": "workspace:*",
    "@integrations/logger": "workspace:*",
    "@logtape/logtape": "catalog:",
    "@orpc/openapi": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/zod": "^1.13.4",
    "@scheduling/db": "workspace:*",
    "@scheduling/dto": "workspace:*",
    "@swc/core": "^1.15.11",
    "better-auth": "^1.4.18",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "catalog:",
    "es-toolkit": "^1.44.0",
    "hono": "^4.11.9",
    "inngest": "^3.52.0",
    "libphonenumber-js": "^1.12.36",
    "luxon": "^3.7.2",
    "parse-duration": "^2.1.5",
    "resend": "^6.9.2",
    "rrule": "^2.8.1",
    "standardenv": "^0.0.2",
    "svix": "^1.84.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@inngest/test": "^0.1.9",
    "@types/bun": "catalog:",
    "@types/luxon": "^3.7.1",
    "typescript": "catalog:"
  }
}
