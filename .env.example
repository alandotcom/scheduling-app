DATABASE_URL=postgres://scheduling:scheduling@localhost:5433/scheduling
# Optional URL used only by `pnpm bootstrap:dev` for `drizzle-kit push`
# (use a role with permission across app schemas)
# DB_PUSH_DATABASE_URL=postgres://scheduling:scheduling@localhost:5433/scheduling
# Used by `pnpm db:reset` to drop/recreate the database.
# DATABASE_ADMIN_URL=postgres://scheduling:scheduling@localhost:5433/postgres
AUTH_SECRET=change-this-secret-in-production
# Optional API server port alias used by package scripts (falls back to PORT)
# API_PORT=3000
PORT=3000
# Optional Inngest runtime URL.
# Defaults to http://127.0.0.1:8288 in local development.
# Self-hosted: http://localhost:8288
# INNGEST_BASE_URL=http://localhost:8288
# Optional Inngest auth keys.
# INNGEST_EVENT_KEY defaults to "dev" in local development.
# Both keys are required in non-dev/self-hosted deployments.
# INNGEST_EVENT_KEY=dev-event-key
# INNGEST_SIGNING_KEY=dev-signing-key
# Optional override for serve endpoint detection.
# INNGEST_SERVE_PATH=/api/inngest
# INNGEST_SERVE_HOST=http://localhost:3000
# trace|debug|info|warning|error|fatal
# Defaults to debug in non-production, info in production
# LOG_LEVEL=debug
SVIX_WEBHOOKS_ENABLED=false
# Comma-separated enabled integration names (for example: svix,logger)
INTEGRATIONS_ENABLED=svix
# Required to encrypt org integration secrets (API keys, OAuth tokens)
# INTEGRATIONS_ENCRYPTION_KEY=change-this-integration-encryption-key

# OAuth state signing key for org-level integrations
# INTEGRATIONS_OAUTH_STATE_SIGNING_KEY=change-this-oauth-state-signing-key

# Slack OAuth integration (org-level bot install)
# INTEGRATIONS_SLACK_CLIENT_ID=
# INTEGRATIONS_SLACK_CLIENT_SECRET=
# INTEGRATIONS_SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/oauth/slack/callback
# Optional comma-separated bot scopes
# INTEGRATIONS_SLACK_SCOPES=chat:write
# Optional (required when SVIX_WEBHOOKS_ENABLED=true)
# Hosted:
# SVIX_BASE_URL=https://api.svix.com
# SVIX_AUTH_TOKEN=svix_live_xxx
# Self-hosted (docker-compose svix service):
# SVIX_BASE_URL=http://localhost:8071
# SVIX_JWT_SECRET=change-this-svix-jwt-secret
# Generate a token from the running svix container and set SVIX_AUTH_TOKEN:
# docker exec -it scheduling-svix svix-server jwt generate
