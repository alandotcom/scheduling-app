DATABASE_URL=postgres://scheduling:scheduling@localhost:5433/scheduling
# Optional URL used only by `pnpm bootstrap:dev` for `drizzle-kit push`
# (use a role with permission across app + workflow schemas)
# DB_PUSH_DATABASE_URL=postgres://scheduling:scheduling@localhost:5433/scheduling
# Optional Workflow Postgres URL used by bootstrap + workflow worker.
# WORKFLOW_POSTGRES_URL=postgres://scheduling:scheduling@localhost:5433/scheduling
# Used by `pnpm db:reset` to drop/recreate the database.
# DATABASE_ADMIN_URL=postgres://scheduling:scheduling@localhost:5433/postgres
# Optional: if set, this takes precedence over VALKEY_HOST/VALKEY_PORT
# REDIS_URL=redis://localhost:6380
VALKEY_HOST=localhost
VALKEY_PORT=6380
AUTH_SECRET=change-this-secret-in-production
# Optional API server port alias used by package scripts (falls back to PORT)
# API_PORT=3000
PORT=3000
# trace|debug|info|warning|error|fatal
# Defaults to debug in non-production, info in production
# LOG_LEVEL=debug
BULL_BOARD_HOST=127.0.0.1
BULL_BOARD_PORT=3010
BULL_BOARD_BASE_PATH=/
WORKFLOW_WORKER_HOST=127.0.0.1
WORKFLOW_WORKER_PORT=3020
# Optional explicit world target (workflow worker scripts set this automatically)
# WORKFLOW_TARGET_WORLD=@workflow/world-postgres
# Optional explicit Workflow Postgres world URL (falls back to DATABASE_URL)
# WORKFLOW_POSTGRES_URL=postgres://scheduling:scheduling@localhost:5433/scheduling
SVIX_WEBHOOKS_ENABLED=false
# Comma-separated enabled integration names (for example: svix,logger)
INTEGRATIONS_ENABLED=svix
# Optional (required when SVIX_WEBHOOKS_ENABLED=true)
# Hosted:
# SVIX_BASE_URL=https://api.svix.com
# SVIX_AUTH_TOKEN=svix_live_xxx
# Self-hosted (docker-compose svix service):
# SVIX_BASE_URL=http://localhost:8071
# SVIX_JWT_SECRET=change-this-svix-jwt-secret
# Generate a token from the running svix container and set SVIX_AUTH_TOKEN:
# docker exec -it scheduling-svix svix-server jwt generate
